# ──────────────────────────────────────────────
# NutricIA Frontend — Environment Variables
# Copy to .env and fill in your values
# ──────────────────────────────────────────────

# API base URL
# - Expo Go on physical device: use your PC LAN IP (e.g. http://192.168.1.10:8000/api/v1)
# - Android emulator: http://10.0.2.2:8000/api/v1
# - iOS simulator / web: http://localhost:8000/api/v1
EXPO_PUBLIC_API_URL=http://localhost:8000/api/v1

# ── OAuth ──────────────────────────────────────
# Google OAuth Client ID (for expo-auth-session)
# Get from https://console.cloud.google.com/apis/credentials
# Create an OAuth 2.0 Client ID → iOS/Android app
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Apple OAuth Client ID (Services ID)
# Get from https://developer.apple.com/account/resources/identifiers/list/serviceId
EXPO_PUBLIC_APPLE_CLIENT_ID=app.nutricia.client
