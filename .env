# ──────────────────────────────────────────────
# NutricIA Frontend — Local Environment Variables
# ──────────────────────────────────────────────

# API base URL (use localhost for local dev, Docker service name in containers)
EXPO_PUBLIC_API_URL=http://localhost:8000/api/v1

# Google OAuth Client ID (for expo-auth-session)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
